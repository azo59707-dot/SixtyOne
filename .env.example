# Discord OAuth2 — من https://discord.com/developers/applications
DISCORD_CLIENT_ID=YOUR_DISCORD_CLIENT_ID
DISCORD_CLIENT_SECRET=YOUR_DISCORD_CLIENT_SECRET
DISCORD_REDIRECT_URI=https://YOUR_RAILWAY_URL/auth/discord/callback

# Session secret — اكتب أي نص عشوائي طويل
SESSION_SECRET=change_this_to_random_long_string_123456

# اسم الأدمن على Discord (أي مستخدم يكون أدمن)
ADMIN_DISCORD_IDS=123456789012345678,987654321098765432

PORT=3000
